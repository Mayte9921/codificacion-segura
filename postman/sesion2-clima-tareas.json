{
  "info": {
    "name": "Sesión 2 - Clima y Tareas con Autenticación",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "📝 Registrar usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"alumno@demo.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/registro",
              "host": ["{{base_url}}"],
              "path": ["auth", "registro"]
            }
          }
        },
        {
          "name": "🔑 Iniciar sesión",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"alumno@demo.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "👤 Ver perfil",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/perfil",
              "host": ["{{base_url}}"],
              "path": ["auth", "perfil"]
            }
          }
        }
      ]
    },
    {
      "name": "Tareas (protegidas)",
      "item": [
        {
          "name": "📋 Listar tareas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tareas",
              "host": ["{{base_url}}"],
              "path": ["tareas"]
            }
          }
        },
        {
          "name": "📝 Crear tarea",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Estudiar para el examen\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tareas",
              "host": ["{{base_url}}"],
              "path": ["tareas"]
            }
          }
        },
        {
          "name": "✏️ Actualizar tarea",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"completada\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/tareas/1",
              "host": ["{{base_url}}"],
              "path": ["tareas", "1"]
            }
          }
        },
        {
          "name": "🗑️ Eliminar tarea",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tareas/1",
              "host": ["{{base_url}}"],
              "path": ["tareas", "1"]
            }
          }
        },
        {
          "name": "🌤️ Tarea con clima",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tareas/1/clima?ciudad=Madrid",
              "host": ["{{base_url}}"],
              "path": ["tareas", "1", "clima"],
              "query": [
                {
                  "key": "ciudad",
                  "value": "Madrid"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Clima (protegido)",
      "item": [
        {
          "name": "🌤️ Clima independiente",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/clima/Madrid",
              "host": ["{{base_url}}"],
              "path": ["clima", "Madrid"]
            }
          }
        },
        {
          "name": "❌ Error: ciudad inválida",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/clima/123",
              "host": ["{{base_url}}"],
              "path": ["clima", "123"]
            }
          }
        }
      ]
    },
    {
      "name": "Pruebas de error",
      "item": [
        {
          "name": "❌ Sin token (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tareas",
              "host": ["{{base_url}}"],
              "path": ["tareas"]
            }
          }
        },
        {
          "name": "❌ Tarea no encontrada (404)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tareas/999",
              "host": ["{{base_url}}"],
              "path": ["tareas", "999"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}